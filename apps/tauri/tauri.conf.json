{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fluxby",
  "version": "1.3.0",
  "identifier": "com.fluxby.desktop",
  "build": {
    "frontendDist": "../web/dist",
    "devUrl": "http://localhost:5178/",
    "beforeDevCommand": "npm run dev:web --prefix ../..",
    "beforeBuildCommand": "npm run build:web --prefix ../.."
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Fluxby - Financieel Dashboard",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' http://localhost:* https://localhost:* wss://*"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app",
      "dmg",
      "nsis",
      "appimage",
      "deb"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "externalBin": [],
    "category": "Finance",
    "shortDescription": "Lokale financiële visualisatie app",
    "longDescription": "Een privacy-first financieel dashboard voor het visualiseren van bank transacties. Al je data blijft lokaal op je apparaat.",
    "copyright": "© 2026 Fluxby",
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null,
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "wix": null,
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      },
      "deb": {
        "depends": []
      }
    }
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
