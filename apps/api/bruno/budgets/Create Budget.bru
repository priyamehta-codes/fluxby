meta {
  name: Create Budget
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/budgets
  body: json
  auth: none
}

headers {
  X-Profile-Id: {{profileId}}
}

body:json {
  {
    "categoryId": 5,
    "amount": 500,
    "period": "monthly"
  }
}

docs {
  # Create Budget
  
  Creates a new budget for a category.
  
  ## Request Body
  
  - `categoryId` (required): Category ID to budget for
  - `amount` (required): Budget amount
  - `period` (required): Budget period (monthly, yearly)
}
