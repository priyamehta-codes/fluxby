meta {
  name: Get Account by ID
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/accounts/:id
  body: none
  auth: none
}

params:path {
  id: 1
}

headers {
  X-Profile-Id: {{profileId}}
}

docs {
  # Get Account by ID
  
  Retrieves a single account by its ID.
  
  ## Headers
  
  - `X-Profile-Id`: Profile ID (optional)
  
  ## Path Parameters
  
  - `id` (required): Account ID
}
