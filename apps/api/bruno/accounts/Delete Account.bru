meta {
  name: Delete Account
  type: http
  seq: 5
}

delete {
  url: {{baseUrl}}/accounts/:id
  body: none
  auth: none
}

params:path {
  id: 1
}

headers {
  X-Profile-Id: {{profileId}}
}

docs {
  # Delete Account
  
  Deletes a bank account and all associated transactions.
  
  ## Path Parameters
  
  - `id` (required): Account ID to delete
  
  ## Warning
  
  This will permanently delete all transactions associated with this account.
}
